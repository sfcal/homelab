---
services:
  romm-db:
    image: {{ romm_db_image }}
    container_name: romm-db
    restart: unless-stopped
    environment:
      - MARIADB_ROOT_PASSWORD={{ romm_db_root_password }}
      - MARIADB_DATABASE=romm
      - MARIADB_USER=romm-user
      - MARIADB_PASSWORD={{ romm_db_password }}
    volumes:
      - "{{ romm_deploy_path }}/db:/var/lib/mysql"
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      retries: 5
      start_period: 10s
    networks:
      - romm-net

  romm-valkey:
    image: {{ romm_valkey_image }}
    container_name: romm-valkey
    restart: unless-stopped
    networks:
      - romm-net

  romm:
    image: {{ romm_image }}
    container_name: romm
    restart: unless-stopped
    ports:
      - "{{ romm_port }}:8080"
    environment:
      - DB_HOST=romm-db
      - DB_NAME=romm
      - DB_USER=romm-user
      - DB_PASSWD={{ romm_db_password }}
      - ROMM_AUTH_SECRET_KEY={{ romm_auth_secret }}
      - IGDB_CLIENT_ID={{ romm_igdb_client_id }}
      - IGDB_CLIENT_SECRET={{ romm_igdb_client_secret }}
      - REDIS_HOST=romm-valkey
      - REDIS_PORT=6379
    volumes:
      - "{{ romm_deploy_path }}/resources:/romm/resources"
      - "{{ romm_deploy_path }}/redis:/redis-data"
      - "{{ romm_deploy_path }}/config:/romm/config"
      - {{ wolf_roms_path }}:/romm/library
    depends_on:
      romm-db:
        condition: service_healthy
      romm-valkey:
        condition: service_started
    networks:
      - romm-net

networks:
  romm-net:
    driver: bridge
