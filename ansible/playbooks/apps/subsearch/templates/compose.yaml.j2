---
services:
  meilisearch:
    image: {{ apps[app_name].image }}
    container_name: subsearch
    restart: unless-stopped
    mem_limit: 2g
    mem_reservation: 512m
    environment:
      - MEILI_ENV=production
      - MEILI_NO_ANALYTICS=true
      - "MEILI_MASTER_KEY={{ subsearch_master_key }}"
    ports:
      - "{{ apps[app_name].port }}:7700"
    volumes:
      - ./meilisearch-data:/meili_data

  indexer:
    image: {{ apps[app_name].indexer_image }}
    container_name: subsearch-indexer
    restart: unless-stopped
    mem_limit: 512m
    mem_reservation: 256m
    environment:
      - MEILI_URL=http://meilisearch:7700
      - "MEILI_MASTER_KEY={{ subsearch_master_key }}"
      - INDEX_INTERVAL={{ apps[app_name].index_interval }}
      - MEDIA_PATH=/media
    volumes:
      - ./indexer-data:/data
      - /mnt/data/media:/media:ro
    depends_on:
      - meilisearch
