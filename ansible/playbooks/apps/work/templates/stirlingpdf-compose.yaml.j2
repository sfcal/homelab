---
services:
  stirling-pdf:
    image: {{ stirlingpdf_image }}
    container_name: stirling-pdf
    restart: unless-stopped
    ports:
      - "{{ stirlingpdf_port }}:8080"
    volumes:
      - {{ stirlingpdf_deploy_path }}/configs:/configs
      - {{ stirlingpdf_deploy_path }}/logs:/logs
      - {{ stirlingpdf_deploy_path }}/data:/usr/share/tessdata
