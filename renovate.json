{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchCategories": [
        "docker"
      ],
      "enabled": true,
      "pinDigests": false
    },
    {
      "description": "Auto-merge patch after 1 day",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "minimumReleaseAge": "1 day",
      "automergeType": "pr"
    },
    {
      "description": "Auto-merge minor after 3 days",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true,
      "minimumReleaseAge": "3 days",
      "automergeType": "pr"
    },
    {
      "description": "Manual review for major",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "minimumReleaseAge": "7 days"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Ansible group_vars Docker image references",
      "fileMatch": ["ansible/environments/.+/group_vars/.+\\.yml$"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\n\\s*\\w+:\\s*\"(?<depName>[^:]+):(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "docker"
    }
  ],
  "schedule": [
    "before 6am every weekday"
  ],
  "minimumReleaseAge": "1 day"
}
