{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchCategories": [
        "docker"
      ],
      "enabled": true,
      "pinDigests": false
    },
    {
      "description": "Auto-merge patch immediately",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "minimumReleaseAge": "0 days",
      "automergeType": "pr"
    },
    {
      "description": "Auto-merge minor after 1 day",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true,
      "minimumReleaseAge": "1 day",
      "automergeType": "pr"
    },
    {
      "description": "Auto-merge major after 3 days",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": true,
      "minimumReleaseAge": "3 days",
      "automergeType": "pr"
    },
    {
      "description": "Auto-merge GitHub Actions immediately",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true,
      "minimumReleaseAge": "0 days",
      "automergeType": "pr"
    },
    {
      "description": "Pin pulsarr to 0.x (no v1 exists on Docker Hub)",
      "matchPackageNames": [
        "lakker/pulsarr"
      ],
      "allowedVersions": "<1.0.0"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Ansible group_vars Docker image references",
      "managerFilePatterns": [
        "/ansible/environments/.+/group_vars/.+\\.yml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\n\\s*\\w+:\\s*\"(?<depName>[^:]+):(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "docker"
    }
  ],
  "hostRules": [
    {
      "hostType": "docker",
      "matchHost": "docker.io",
      "username": "{{ secrets.DOCKER_HUB_USERNAME }}",
      "password": "{{ secrets.DOCKER_HUB_PASSWORD }}"
    }
  ],
  "schedule": [
    "before 6am every weekday"
  ],
  "minimumReleaseAge": "1 day"
}
